# Required by LiteLLM to call OpenAI-hosted models.
OPENAI_API_KEY=

# Each node initializes its own LangChain/LiteLLM model, configured here.
# MODEL is required per node; TEMPERATURE/TOP_P are optional (LiteLLM/provider default if unset).

# src_v2/nodes/setting_selection.py — picks settings from the catalog for the persona.
SETTING_SELECTION_MODEL=gpt-4.1-2025-04-14
SETTING_SELECTION_TEMPERATURE=
SETTING_SELECTION_TOP_P=

# src_v2/nodes/question_generation.py — generates challenge questions per task.
QUESTION_GENERATION_MODEL=gpt-4.1-2025-04-14
QUESTION_GENERATION_TEMPERATURE=
QUESTION_GENERATION_TOP_P=

# src_v2/nodes/response_generation.py — role-plays the persona to answer questions.
RESPONSE_GENERATION_MODEL=gpt-4.1-2025-04-14
RESPONSE_GENERATION_TEMPERATURE=
RESPONSE_GENERATION_TOP_P=

# src_v2/nodes/response_evaluation.py — generates per-score calibration examples.
RESPONSE_EVALUATION_EXAMPLE_MODEL=gpt-4.1-2025-04-14
RESPONSE_EVALUATION_EXAMPLE_TEMPERATURE=
RESPONSE_EVALUATION_EXAMPLE_TOP_P=

# src_v2/nodes/response_evaluation.py — LLM judges that score persona responses.
# Comma-separated; scores from each are averaged with equal weight.
# Judge calls are deterministic by default (temperature/top_p pinned to 0).
RESPONSE_EVALUATION_JUDGE_MODELS=gpt-4.1-2025-04-14,gpt-4o-2024-08-06
RESPONSE_EVALUATION_JUDGE_TEMPERATURE=0
RESPONSE_EVALUATION_JUDGE_TOP_P=0
